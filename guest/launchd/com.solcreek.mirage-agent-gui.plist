<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.solcreek.mirage-agent-gui</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/mirage-agent</string>
		<string>serve-gui</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/mirage-agent-gui.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/mirage-agent-gui.log</string>
</dict>
</plist>
